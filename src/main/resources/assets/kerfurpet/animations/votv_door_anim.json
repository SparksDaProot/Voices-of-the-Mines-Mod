{
	"format_version": "1.8.0",
	"animations": {
		"idle_door": {
			"loop": true
		},
		"open_door": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.5,
			"bones": {
				"door_left": {
					"position": {
						"0.0": {
							"vector": [0, 0, 0]
						},
						"0.5": {
							"vector": [15, 0, 0],
							"easing": "easeOutSine"
						}
					}
				},
				"door_right": {
					"position": {
						"0.0": {
							"vector": [0, 0, 0]
						},
						"0.5": {
							"vector": [-15, 0, 0],
							"easing": "easeOutSine"
						}
					}
				}
			}
		},
		"close_door": {
			"loop": "hold_on_last_frame",
			"animation_length": 0.5,
			"bones": {
				"door_left": {
					"position": {
						"0.0": {
							"vector": [15, 0, 0],
							"easing": "linear"
						},
						"0.5": {
							"vector": [0, 0, 0],
							"easing": "easeOutSine"
						}
					}
				},
				"door_right": {
					"position": {
						"0.0": {
							"vector": [-15, 0, 0],
							"easing": "linear"
						},
						"0.5": {
							"vector": [0, 0, 0],
							"easing": "easeOutSine"
						}
					}
				}
			}
		}
	}
}